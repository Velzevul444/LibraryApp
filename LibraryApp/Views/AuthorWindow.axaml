<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LibraryApp.ViewModels"
        x:Class="LibraryApp.Views.AuthorWindow"
        x:DataType="vm:AuthorViewModel"
        Title="Авторы" Width="400" Height="300">
    <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="5">
            <Button Content="Добавить" Command="{Binding AddCommand}" />
            <Button Content="Изменить" Command="{Binding EditCommand}" Margin="5,0" />
            <Button Content="Удалить" Command="{Binding DeleteCommand}" />
        </StackPanel>
        <DataGrid ItemsSource="{Binding Authors}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" />
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" />
                <DataGridTextColumn Header="Страна" Binding="{Binding Country}" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
